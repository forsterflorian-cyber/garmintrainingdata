# App mode. Use production on deployed instances.
APP_ENV=development

# Required for both the browser client and the server-side Supabase client.
SUPABASE_URL=https://your-project-ref.supabase.co

# Required for browser sign-in inside the dashboard shell.
SUPABASE_ANON_KEY=your-supabase-anon-key

# Required for server-side writes, sync state, and account deletion.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Required only when Supabase access tokens are verified with HS256.
# Leave empty when your project uses JWKS / RS256 verification.
SUPABASE_JWT_SECRET=

# Required for encrypting stored Garmin credentials and Garmin sessions.
APP_SECRET_KEY=replace-with-a-long-random-secret

# Optional sync tuning. Defaults shown here.
SYNC_FRESHNESS_HOURS=6
SYNC_STALE_HOURS=12
SYNC_BACKFILL_THRESHOLD_DAYS=3
SYNC_AUTO_BACKFILL_LIMIT_DAYS=3
SYNC_INITIAL_BACKFILL_DAYS=180
SYNC_MISSING_DAYS_WINDOW_DAYS=180
SYNC_INCREMENTAL_SYNC_DAYS=3
SYNC_INCREMENTAL_GAP_FILL_DAYS=3
SYNC_LOCK_TTL_SECONDS=600
SYNC_POLL_SECONDS=5

# Optional browser-test override when Chrome or Edge is not in the default path.
PLAYWRIGHT_CHROME_EXECUTABLE=
